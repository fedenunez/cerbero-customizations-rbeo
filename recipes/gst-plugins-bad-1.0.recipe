# -*- Mode: Python -*- vi:si:et:sw=4:sts=4:ts=4:syntax=python
#
# LOCAL OVERRIDE of upstream gst-plugins-bad-1.0.
#
# rbeolibs only needs the WebRTC plugins out of gst-plugins-bad. Building the full
# plugin set drags in fragile/unneeded plugins (e.g. SoundTouch fails to link on
# Android) and the software openh264 H.264 codec (patent exposure). So we build a
# MINIMAL gst-plugins-bad: `auto_features=disabled` turns everything off, then we
# re-enable only what webrtcbin needs, plus the OS hardware H.264 codecs
# (applemedia / androidmedia) which carry no MPEG-LA royalty.
#
# Re-sync the tarball_checksum (and review meson option names / file lists) when
# bumping the Cerbero version.

class Recipe(custom.GStreamer):
    name = 'gst-plugins-bad-1.0'
    btype = BuildType.MESON
    if custom.GStreamer.stype == SourceType.TARBALL:
        licenses = [{License.LGPLv2Plus: None, License.BSD_3_Clause: ['ext/sctp/usrsctp/LICENSE.md']}]
    else:
        licenses = [{License.LGPLv2Plus: None, License.BSD_3_Clause: ['subprojects/gst-plugins-bad/ext/sctp/usrsctp/LICENSE.md']}]
    tarball_checksum = '4213f43ddb875bb141e5040e97735579d74665bec3d17b51052aade395b83f00'

    # Disable every plugin by default, then explicitly enable the WebRTC set.
    meson_options = {
        'auto_features': 'disabled',
        # The applemedia/androidmedia hardware H.264 codecs require GstGL; in
        # gst-plugins-bad meson.build `gstgl_dep` is only looked up when the `gl`
        # option is enabled (required: get_option('gl')). auto_features=disabled
        # turns it off, so enable it explicitly. GstGL itself comes from
        # gst-plugins-base (built on all mobile platforms).
        'gl': 'enabled',
        'dtls': 'enabled',
        'sctp': 'enabled',
        'sctp-internal-usrsctp': 'enabled',
        'srtp': 'enabled',
        'webrtc': 'enabled',
        'webrtcdsp': 'enabled',
    }

    # Only the deps the enabled plugins need.
    deps = ['gstreamer-1.0', 'gst-plugins-base-1.0',
            'libnice', 'openssl', 'libsrtp', 'webrtc-audio-processing']

    # gst-plugins-bad builds its gst-libs (gst-libs/gst/*) and runs
    # install_headers() UNCONDITIONALLY -- `auto_features=disabled` only gates
    # PLUGINS, not these helper libraries. So every one of them lands in each
    # per-arch prefix regardless of our minimal plugin set. The iOS framework
    # packager copies headers from the merged `ios_universal` prefix, and the
    # universal-merge only carries across files that a recipe explicitly lists.
    # If we list only the webrtc subset, the merge drops the other gst-lib
    # headers and the packager dies one-by-one (analytics-meta-prelude.h, then
    # audio-bad-prelude.h, ...). So we mirror upstream's full gst-lib library +
    # header set here -- they are always built anyway -- and only EXCLUDE
    # `vulkan`, the one gst-lib our no-Vulkan config never produces (listing it
    # would point the merge at a file that does not exist). All LGPL, deps are
    # core/base only. Re-sync against upstream gst-plugins-bad-1.0.recipe when
    # bumping Cerbero.
    files_libs = [
        'libgstadaptivedemux-1.0',
        'libgstanalytics-1.0',
        'libgstbadaudio-1.0',
        'libgstbasecamerabinsrc-1.0',
        'libgstcodecparsers-1.0',
        'libgstcodecs-1.0',
        'libgstinsertbin-1.0',
        'libgstisoff-1.0',
        'libgstmpegts-1.0',
        'libgstmse-1.0',
        'libgstphotography-1.0',
        'libgstplay-1.0',
        'libgstplayer-1.0',
        'libgstsctp-1.0',
        'libgsttranscoder-1.0',
        'libgsturidownloader-1.0',
        'libgstwebrtc-1.0',
        'libgstwebrtcnice-1.0',
    ]

    files_plugins_devel = [
        'include/gstreamer-1.0/gst/analytics',
        'include/gstreamer-1.0/gst/audio',
        'include/gstreamer-1.0/gst/base',
        'include/gstreamer-1.0/gst/basecamerabinsrc',
        'include/gstreamer-1.0/gst/codecparsers',
        'include/gstreamer-1.0/gst/insertbin',
        'include/gstreamer-1.0/gst/interfaces',
        'include/gstreamer-1.0/gst/isoff',
        'include/gstreamer-1.0/gst/mpegts',
        'include/gstreamer-1.0/gst/mse',
        'include/gstreamer-1.0/gst/play',
        'include/gstreamer-1.0/gst/player',
        'include/gstreamer-1.0/gst/sctp',
        'include/gstreamer-1.0/gst/transcoder',
        'include/gstreamer-1.0/gst/webrtc',
        '%(libdir)s/pkgconfig/gstreamer-analytics-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-bad-audio-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-codecparsers-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-insertbin-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-mpegts-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-mse-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-photography-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-play-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-player-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-sctp-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-transcoder-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-webrtc-1.0.pc',
        '%(libdir)s/pkgconfig/gstreamer-webrtc-nice-1.0.pc',
    ]

    files_plugins_net = [
        '%(libdir)s/gstreamer-1.0/libgstdtls%(mext)s',
        '%(libdir)s/gstreamer-1.0/libgstsctp%(mext)s',
        '%(libdir)s/gstreamer-1.0/libgstsrtp%(mext)s',
        '%(libdir)s/gstreamer-1.0/libgstwebrtc%(mext)s',
    ]
    files_plugins_net_devel = [
        '%(libdir)s/gstreamer-1.0/libgstdtls.a', '%(libdir)s/gstreamer-1.0/libgstdtls.la',
        '%(libdir)s/gstreamer-1.0/libgstsctp.a', '%(libdir)s/gstreamer-1.0/libgstsctp.la',
        '%(libdir)s/gstreamer-1.0/libgstsrtp.a', '%(libdir)s/gstreamer-1.0/libgstsrtp.la',
        '%(libdir)s/gstreamer-1.0/libgstwebrtc.a', '%(libdir)s/gstreamer-1.0/libgstwebrtc.la',
    ]

    files_plugins_effects = [
        '%(libdir)s/gstreamer-1.0/libgstwebrtcdsp%(mext)s',
    ]
    files_plugins_effects_devel = [
        '%(libdir)s/gstreamer-1.0/libgstwebrtcdsp.a', '%(libdir)s/gstreamer-1.0/libgstwebrtcdsp.la',
    ]

    # Hardware H.264 (no software openh264): VideoToolbox on Apple, MediaCodec on
    # Android. Base categories are empty; the platform extensions add the plugin.
    files_plugins_codecs = []
    files_plugins_codecs_devel = []
    platform_files_plugins_codecs = {
        Platform.ANDROID: [
            '%(libdir)s/gstreamer-1.0/libgstandroidmedia%(mext)s',
        ],
    }
    platform_files_plugins_codecs_devel = {
        Platform.ANDROID: [
            '%(libdir)s/gstreamer-1.0/libgstandroidmedia.a', '%(libdir)s/gstreamer-1.0/libgstandroidmedia.la',
        ],
    }

    files_plugins_sys = []
    files_plugins_sys_devel = []
    platform_files_plugins_sys = {
        Platform.DARWIN: [
            '%(libdir)s/gstreamer-1.0/libgstapplemedia%(mext)s',
        ],
        Platform.IOS: [
            '%(libdir)s/gstreamer-1.0/libgstapplemedia%(mext)s',
        ],
    }
    platform_files_plugins_sys_devel = {
        Platform.DARWIN: [
            '%(libdir)s/gstreamer-1.0/libgstapplemedia.a', '%(libdir)s/gstreamer-1.0/libgstapplemedia.la',
        ],
        Platform.IOS: [
            '%(libdir)s/gstreamer-1.0/libgstapplemedia.a', '%(libdir)s/gstreamer-1.0/libgstapplemedia.la',
        ],
    }

    def prepare(self):
        # OS hardware H.264 (royalty covered by the device's MPEG-LA license).
        if Platform.is_apple(self.config.target_platform):
            self.meson_options['applemedia'] = 'enabled'
        if self.config.target_platform == Platform.ANDROID:
            self.meson_options['androidmedia'] = 'enabled'
